import Layout from '../layouts/Layout.astro';
---

<Layout title="Cain Anthony Macias | Business Systems Engineer">
  <div class="fixed inset-0 -z-10 bg-zinc-950">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:32px_32px]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(at_top_center,rgba(63,63,70,0.15)_0%,transparent_80%)]"></div>
  </div>

  <header class="mb-16 mt-12 flex flex-col-reverse md:flex-row gap-8 items-center md:items-start">
    <div class="flex-1 text-center md:text-left">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-2 tracking-tight">Cain Anthony Macias</h1>
      <h2 class="text-xl md:text-2xl text-zinc-400 mb-8 font-medium leading-tight">
        Business Systems Engineer <br class="hidden md:block"/>
        <span class="text-zinc-500 text-lg md:text-xl font-normal italic">MBA Candidate: Data Analytics & Healthcare Administration</span>
      </h2>
      
      <div class="space-y-6 text-lg leading-relaxed text-zinc-300 max-w-2xl">
        <p>
          I design and improve operational systems that ensure data accuracy, inventory integrity, and reliable business workflows across ERP and cloud platforms. My work focuses on solving real operational problems such as manual reconciliation, data inconsistencies, and inefficient workflows by building scalable systems that reduce errors and improve efficiency.
        </p>
        <p>
          I have led initiatives including a 500,000 plus record enterprise migration with zero downtime and developed automation pipelines that eliminated 15 plus hours of manual work per week while improving data reliability across systems.
        </p>
      </div>
    </div>
    
    <div class="w-48 h-48 md:w-64 md:h-64 shrink-0">
      <img 
        src="/profile.jpg" 
        alt="Cain Anthony Macias" 
        class="rounded-2xl border border-zinc-800 grayscale hover:grayscale-0 transition-all duration-700 shadow-2xl object-cover w-full h-full bg-zinc-900"
      />
    </div>
  </header>

  <section class="mb-12">
    <h3 class="text-xs uppercase tracking-[0.2em] text-zinc-500 font-bold mb-6">Professional Certifications</h3>
    <div class="flex flex-wrap gap-3">
      <span class="px-4 py-2 bg-zinc-900/50 border border-zinc-800 text-zinc-300 rounded-lg text-sm font-medium">Google Certified Project Manager</span>
      <span class="px-4 py-2 bg-zinc-900/50 border border-zinc-800 text-zinc-300 rounded-lg text-sm font-medium">IBM Certified Business Analyst</span>
      <span class="px-4 py-2 bg-white/10 border border-white/30 text-white rounded-lg text-sm font-medium ring-1 ring-white/10">MBA Candidate | 4.0 GPA</span>
    </div>
  </section>

  <section class="mb-16">
    <h3 class="text-xl font-semibold text-white border-b border-zinc-800 pb-3 mb-8">Education</h3>
    <div class="space-y-8">
      <div>
        <div class="flex flex-col md:flex-row md:justify-between items-start md:items-center mb-1">
          <h4 class="text-zinc-100 font-bold text-lg">Master of Business Administration (MBA)</h4>
          <span class="text-zinc-500 font-mono text-sm">Expected 2027</span>
        </div>
        <p class="text-zinc-400 font-medium">Texas A&M University-Corpus Christi</p>
        <p class="text-zinc-500 text-sm mt-1">Dual Concentration: Business Analytics & Healthcare Administration | GPA: 4.0</p>
      </div>

      <div>
        <div class="flex flex-col md:flex-row md:justify-between items-start md:items-center mb-1">
          <h4 class="text-zinc-100 font-bold text-lg">Bachelor of Applied Science (BAS)</h4>
          <span class="text-zinc-500 font-mono text-sm">Completed</span>
        </div>
        <p class="text-zinc-400 font-medium">Del Mar College</p>
        <p class="text-zinc-500 text-sm mt-1">Organizational Management & Leadership | Honors: President's List</p>
      </div>

      <div>
        <div class="flex flex-col md:flex-row md:justify-between items-start md:items-center mb-1">
          <h4 class="text-zinc-100 font-bold text-lg">Associate of Applied Science (AAS)</h4>
          <span class="text-zinc-500 font-mono text-sm">Completed</span>
        </div>
        <p class="text-zinc-400 font-medium">Del Mar College</p>
        <p class="text-zinc-500 text-sm mt-1">Medical Laboratory Technology</p>
      </div>
    </div>
  </section>

  <section class="border-t border-zinc-900 pt-12 pb-24 text-center md:text-left">
    <h3 class="text-2xl font-bold text-white mb-6 tracking-tight">Operational Systems & Case Studies</h3>
    <p class="text-zinc-400 mb-8 max-w-xl text-lg">Case studies on inventory reconciliation, process automation, and high integrity data migrations for enterprise operations.</p>
    <a href="/projects" class="inline-flex items-center justify-center bg-white text-zinc-950 font-bold px-8 py-4 rounded-lg hover:bg-zinc-200 transition-all hover:scale-[1.02] active:scale-95 shadow-xl shadow-white/5">
      View Operational Systems &rarr;
    </a>
  </section>
</Layout>
