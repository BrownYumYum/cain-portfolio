---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cain Anthony Macias | Systems Engineer">
  <main class="max-w-4xl mx-auto px-4 py-20">
    
    <header class="mb-16">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 tracking-tight">
        Cain Anthony Macias
      </h1>
      <h2 class="text-2xl md:text-3xl text-blue-400 font-medium mb-6">
        Systems Engineer & Operations Technology Analyst
      </h2>
      <p class="text-lg text-zinc-400 leading-relaxed max-w-2xl mb-8">
        I build automated pipelines, robust ETL engines, and data-driven dashboards to bridge the gap between technical operations and business intelligence. Currently an MBA candidate specializing in Data Analytics and Healthcare Administration, I focus on transforming raw systems data into actionable enterprise solutions using Python, Django, and AWS.
      </p>
      
      <div class="flex flex-wrap gap-4">
        <a href="/projects" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors">
          View Enterprise Projects
        </a>
        <a href="mailto:your.email@example.com" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-white font-bold py-3 px-6 rounded-lg transition-colors">
          Contact Me
        </a>
      </div>
    </header>

    <section class="border-t border-zinc-800 pt-12">
      <h3 class="text-sm font-bold text-zinc-500 uppercase tracking-wider mb-6">Core Infrastructure & Stack</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-zinc-300 font-mono text-sm">
        <div class="bg-zinc-900/50 border border-zinc-800 p-4 rounded-lg">
          <span class="block text-blue-400 mb-1">Backend</span>
          Python, Django, Celery
        </div>
        <div class="bg-zinc-900/50 border border-zinc-800 p-4 rounded-lg">
          <span class="block text-blue-400 mb-1">Data & ETL</span>
          PostgreSQL, MongoDB, Pandas
        </div>
        <div class="bg-zinc-900/50 border border-zinc-800 p-4 rounded-lg">
          <span class="block text-blue-400 mb-1">Cloud/DevOps</span>
          AWS (EC2/RDS), Docker
        </div>
        <div class="bg-zinc-900/50 border border-zinc-800 p-4 rounded-lg">
          <span class="block text-blue-400 mb-1">Hardware</span>
          RTX Systems, Network Auth
        </div>
      </div>
    </section>

  </main>
</Layout>
